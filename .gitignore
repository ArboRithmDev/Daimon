# Python
__pycache__/
*.py[cod]
*.egg-info/
# Build-stamped version module (generated from pyproject.toml by the build).
/src/daimon/_version.py
.eggs/
dist/
.venv/
.venv-build/
venv/

# PyInstaller build outputs (keep build/ SOURCE: daimon.spec, make_icon.py, macos/)
/build/daimon/
/build/generated-icons/
.pytest_cache/
.ruff_cache/

# Local config holding real exclusion zones (secrets) — never commit
config/exclusions.yaml
config/*.local.yaml

# OS / editor
.DS_Store
.idea/
.vscode/

# Captured frames / scratch
*.png
*.jpg
!docs/**/*.png
# Brand assets that ship inside the package / bundle are tracked.
!src/daimon/assets/*.png

config/motor.yaml
config/motor.state.json
logs/
config/overlay.yaml

# OpenDesign working directory (generated artifacts, not Daimon source)
design/

# Daimon face web bundle build artifacts (rebuilt via build/make_face.py)
src/daimon/face/web/node_modules/
src/daimon/face/web/dist/

# Windows port dev venv
.venv-win/
build_win.log
build/daimon_win/
@AutomationLog.txt
